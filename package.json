{
  "name": "@strapivo/cli",
  "version": "0.1.0",
  "description": "Machine-first CLI for Strapivo Strategic Memory",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strapivo/strapivo-cli.git"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "strapivo": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "skills/strapivo/SKILL.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "npm run clean && npm run build && node --test dist/test/*.test.js",
    "prepack": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
